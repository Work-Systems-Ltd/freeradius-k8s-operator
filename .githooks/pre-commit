#!/usr/bin/env bash
set -euo pipefail

GOPATH_BIN="$(go env GOPATH)/bin"
GOLANGCI_LINT="${GOLANGCI_LINT:-${GOPATH_BIN}/golangci-lint}"
GOIMPORTS="${GOPATH_BIN}/goimports"

if [ ! -x "$GOLANGCI_LINT" ]; then
    echo "golangci-lint not found, installing..."
    go install github.com/golangci/golangci-lint/cmd/golangci-lint@v1.64.8
fi

if [ ! -x "$GOIMPORTS" ]; then
    echo "goimports not found, installing..."
    go install golang.org/x/tools/cmd/goimports@latest
fi

GO_FILES=$(find . -name '*.go' -not -path './vendor/*' -not -path '*/zz_generated*')

echo "Formatting Go files..."
gofmt -w $GO_FILES
"$GOIMPORTS" -w -local github.com/example/freeradius-operator $GO_FILES

# Re-stage any files that were reformatted
git diff --name-only | grep '\.go$' | xargs -r git add || true

echo "Running golangci-lint..."
"$GOLANGCI_LINT" run ./...

echo "Running tests..."
go test $(go list ./... | grep -v /e2e) -count=1 -short

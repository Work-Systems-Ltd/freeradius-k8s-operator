#!/usr/bin/env bash
set -euo pipefail

GOPATH_BIN="$(go env GOPATH)/bin"

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -z "$STAGED" ]; then
    exit 0
fi

echo "Formatting staged Go files..."
echo "$STAGED" | xargs gofmt -w
if [ -x "$GOPATH_BIN/goimports" ]; then
    echo "$STAGED" | xargs "$GOPATH_BIN/goimports" -w -local github.com/example/freeradius-operator
fi
echo "$STAGED" | xargs git add

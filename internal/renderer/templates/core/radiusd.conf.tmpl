# radiusd.conf — generated by freeradius-operator
# DO NOT EDIT MANUALLY

name = freeradius

prefix = /usr
exec_prefix = ${prefix}
localstatedir = /var
sbindir = ${exec_prefix}/sbin
logdir = /var/log/freeradius
raddbdir = /etc/freeradius
confdir = ${raddbdir}
run_dir = ${localstatedir}/run/${name}
db_dir = ${raddbdir}
libdir = /usr/lib/freeradius
pidfile = ${run_dir}/${name}.pid
modconfdir = ${confdir}/mods-config
certdir = ${confdir}/certs
cadir = ${confdir}/certs

max_request_time = 30
cleanup_delay = 5
max_requests = 16384

status_server = yes

log {
    destination = stdout
    colourise = no
    stripped_names = no
    auth = yes
    auth_badpass = no
    auth_goodpass = no
}

security {
    max_attributes = 200
    reject_delay = 1
    status_server = yes
}

thread pool {
    start_servers = 5
    max_servers = 32
    min_spare_servers = 3
    max_spare_servers = 10
    max_requests_per_server = 0
    auto_limit_acct = no
}

$INCLUDE clients.conf
$INCLUDE mods-enabled/
$INCLUDE sites-enabled/

listen {
    type = auth
    ipaddr = *
    port = 1812
}

listen {
    type = auth
    ipv6addr = ::
    port = 1812
}

listen {
    type = acct
    ipaddr = *
    port = 1813
}

listen {
    type = acct
    ipv6addr = ::
    port = 1813
}
{{- if .CoAEnabled }}

listen {
    type = coa
    ipaddr = *
    port = {{ .CoAPort }}
}

listen {
    type = coa
    ipv6addr = ::
    port = {{ .CoAPort }}
}
{{- end }}

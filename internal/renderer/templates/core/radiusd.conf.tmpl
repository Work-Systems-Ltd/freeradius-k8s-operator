# radiusd.conf — generated by freeradius-operator
# DO NOT EDIT MANUALLY

name = freeradius

prefix = /usr
exec_prefix = /usr
sysconfdir = /etc
localstatedir = /var
sbindir = ${exec_prefix}/sbin
logdir = /var/log/freeradius
raddbdir = /etc/freeradius
radacctdir = ${logdir}/radacct
confdir = ${raddbdir}
modconfdir = ${confdir}/mods-config
certdir = ${confdir}/certs
cadir = ${confdir}/certs
run_dir = ${localstatedir}/run/${name}
db_dir = ${raddbdir}
libdir = /usr/lib/freeradius
pidfile = ${run_dir}/${name}.pid
checkrad = ${sbindir}/checkrad

max_request_time = {{ .MaxRequestTime }}
cleanup_delay = 5
max_requests = {{ .MaxRequests }}

status_server = yes

log {
    destination = {{ .Log.Destination }}
    colourise = no
    stripped_names = no
    auth = {{ yesno .Log.Auth }}
    auth_badpass = {{ yesno .Log.AuthBadpass }}
    auth_goodpass = {{ yesno .Log.AuthGoodpass }}
}

security {
    max_attributes = {{ .Security.MaxAttributes }}
    reject_delay = {{ .Security.RejectDelay }}
    status_server = yes
}

thread pool {
    start_servers = {{ .ThreadPool.StartServers }}
    max_servers = {{ .ThreadPool.MaxServers }}
    min_spare_servers = {{ .ThreadPool.MinSpareServers }}
    max_spare_servers = {{ .ThreadPool.MaxSpareServers }}
    max_requests_per_server = {{ .ThreadPool.MaxRequestsPerServer }}
    auto_limit_acct = no
}

$INCLUDE proxy.conf
$INCLUDE clients.conf

modules {
    $INCLUDE mods-enabled/
}

instantiate {
}

policy {
    $INCLUDE policy.d/
}

$INCLUDE sites-enabled/

listen {
    type = auth
    ipaddr = *
    port = 1812
}

listen {
    type = auth
    ipv6addr = ::
    port = 1812
}

listen {
    type = acct
    ipaddr = *
    port = 1813
}

listen {
    type = acct
    ipv6addr = ::
    port = 1813
}
{{- if .CoAEnabled }}

listen {
    type = coa
    ipaddr = *
    port = {{ .CoAPort }}
}

listen {
    type = coa
    ipv6addr = ::
    port = {{ .CoAPort }}
}
{{- end }}
